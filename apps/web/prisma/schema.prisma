// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Users & Roles
model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     String @default("USER") // ADMIN, USER, VET
  approved Boolean @default(false)
  permissions String[] @default([])

  // Extended Profile Fields (Matches App Ganadera)
  firstName String?
  lastName  String?
  dni       String?
  phone     String?
  jobTitle  String?
  dob       DateTime?
  image     String? // URL to profile image

  // Worker/Admin Relationship
  // If this user is a WORKER, who is their ADMIN?
  adminId   String?
  admin     User?   @relation("AdminWorkers", fields: [adminId], references: [id])
  workers   User[]  @relation("AdminWorkers") // If this user is ADMIN, these are their workers

  tasks     Task[]     @relation("AssignedTasks")
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-Tenancy Relations (Owned Data)
  ownedEvents        Event[]           @relation("EventOwner")
  ownedRecipes       Recipe[]          @relation("RecipeOwner")
  ownedIngredients   Ingredient[]      @relation("IngredientOwner")
  ownedSuppliers     Supplier[]        @relation("SupplierOwner")
  ownedTasks         Task[]            @relation("TaskOwner")
  ownedMenuServices  MenuService[]     @relation("MenuServiceOwner")
  ownedAppConfigs    AppConfig[]       @relation("AppConfigOwner")
  ownedStorage       StorageLocation[] @relation("StorageOwner")
  ownedMiseEnPlace   MiseEnPlaceTask[] @relation("MiseEnPlaceOwner")
  
  // Obrador Relations
  ownedObradorConfigs    ObradorConfig[]           @relation("ObradorConfigOwner")
  ownedObradorProducts   ObradorProduct[]          @relation("ObradorProductOwner")
  ownedObradorBatches    ObradorProductionBatch[]  @relation("ObradorBatchOwner")
  ownedObradorIntake     ObradorRawMaterialEntry[] @relation("ObradorIntakeOwner")
  ownedObradorCustomers  ObradorCustomer[]         @relation("ObradorCustomerOwner")
  ownedObradorDocs       ObradorSanitaryDocument[] @relation("ObradorDocOwner")
  ownedObradorTemps      ObradorTemperatureLog[]   @relation("ObradorTempOwner")
  ownedObradorIncidents  ObradorIncident[]         @relation("ObradorIncidentOwner")

  // Locales (multi-location bajo un mismo admin)
  ownedLocations         Location[]                @relation("LocationOwner")
  locationId             String?
  location               Location?                 @relation("LocationMembers", fields: [locationId], references: [id])

  // Checklists (patrón yurest)
  ownedChecklistTemplates  ChecklistTemplate[]   @relation("ChecklistTemplateOwner")
  ownedChecklistSchedules  ChecklistSchedule[]   @relation("ChecklistScheduleOwner")
  closedChecklistInstances ChecklistInstance[]   @relation("ChecklistInstanceClosedBy")
  answeredChecklistResponses ChecklistResponse[] @relation("ChecklistResponseAnsweredBy")
  supervisedChecklistResponses ChecklistResponse[] @relation("ChecklistResponseSupervisedBy")

  // Comunicaciones (averías, avisos, eventos, reuniones)
  authoredCommunications  Communication[]        @relation("CommunicationAuthor")
  authoredCommComments    CommunicationComment[] @relation("CommunicationCommentAuthor")
  ownedCommunications     Communication[]        @relation("CommunicationOwner")

  // Fichaje
  ownedClockIns   ClockIn[] @relation("ClockInOwner")
  workerClockIns  ClockIn[] @relation("ClockInWorker")

  // Solicitudes (vacaciones, ausencias, cambios de turno)
  ownedRequests    EmployeeRequest[] @relation("EmployeeRequestOwner")
  workerRequests   EmployeeRequest[] @relation("EmployeeRequestWorker")
  resolvedRequests EmployeeRequest[] @relation("EmployeeRequestResolver")

  // Turnos
  ownedShifts  Shift[] @relation("ShiftOwner")
  workerShifts Shift[] @relation("ShiftWorker")

  // Pedidos y albaranes
  ownedPurchaseOrders   PurchaseOrder[] @relation("PurchaseOrderOwner")
  createdPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreator")
  receivedDeliveryNotes DeliveryNote[]  @relation("DeliveryNoteReceiver")

  // Etiquetas
  ownedProductLabels   ProductLabel[] @relation("ProductLabelOwner")
  createdProductLabels ProductLabel[] @relation("ProductLabelCreator")

  // Cierres de caja
  ownedCashClosings  CashClosing[] @relation("CashClosingOwner")
  closedCashClosings CashClosing[] @relation("CashClosingCloser")

  // Finanzas (ingresos y gastos)
  ownedFinancialEntries   FinancialEntry[] @relation("FinancialEntryOwner")
  createdFinancialEntries FinancialEntry[] @relation("FinancialEntryCreator")
}

// 7. App Configuration
model AppConfig {
  id      String  @id @default("default")
  logoUrl String? // URL to app logo

  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User?   @relation("AppConfigOwner", fields: [ownerId], references: [id])
}

model RecipeCategory {
  id    String @id @default(cuid())
  name  String @unique
  
  order Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipePackaging {
  id    String @id @default(cuid())
  name  String @unique
  type  String @default("ENVASE") // ENVASE, MOLDE
  
  order Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Ingredients (Productos)
model Ingredient {
  id            String  @id @default(cuid())
  name          String
  category      String?
  pricingUnit   String  @default("KG") // KG, G, L, ML, UD
  pricePerUnit  Float // e.g., 10.50 (Euros)
  yieldPercent  Float   @default(100.0) // 100% means no loss. 80% means 20% loss.
  allergens     String? // SQLite does not support JSON well in standard prisma, usually String or serialized. Wait, Prisma supports JSON in SQLite?
  // "The Json type is supported...". Let's verify.
  allergensJson String? // Store as JSON string explicitly to be safe or use Bytes. 
  // Actually Prisma supports generic Json on SQLite since v3. I will try keeping Json type IF validation allows it.
  // If validation fails for JSON, I will switch to String.
  // Docs say: "SQLite doesn't support JSON type natively but Prisma polyfills it".
  // allergens       Json? // Retrying Json? The validation error before was about ENUMS.

  supplierId String?

  purchaseFormats PurchaseFormat[]
  recipeItems     RecipeItem[]
  recipeSteps     RecipeStep[]

  // New Relation: Ingredient comes from a Transformation Output
  transformationOutputs TransformationOutput[]

  // New Relation: Ingredient variants (SupplierProducts)
  supplierProducts SupplierProduct[]

  // New Relation: Ingredient used in StepIngredients
  recipeStepIngredients RecipeStepIngredient[]

  // Storage Location
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id])
  storageLocationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User?   @relation("IngredientOwner", fields: [ownerId], references: [id])
}

// -----------------------------------------------------------------------------
// NEW: PRODUCT & TRANSFORMATION ARCHITECTURE
// -----------------------------------------------------------------------------

// Canonical Product (e.g. "Aceite de Oliva")
model MasterProduct {
  id          String   @id @default(cuid())
  name        String
  category    String?
  description String?

  supplierProducts SupplierProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Vendor/Provider (e.g. "Makro", "Frutería Pepe")
model Supplier {
  id          String   @id @default(cuid())
  name        String   @unique
  nif         String?
  address     String?
  phone       String?
  contactInfo String?
  email       String?
  contactPerson String?
  productType   String?
  healthRegistry String?
  isActive      Boolean  @default(true)

  products SupplierProduct[]
  obradorIntakes ObradorRawMaterialEntry[]
  purchaseOrders PurchaseOrder[] @relation("PurchaseOrderSupplier")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User?   @relation("SupplierOwner", fields: [ownerId], references: [id])
}

// Lo que compras (SupplierProduct) - Specific variant from a supplier
model SupplierProduct {
  id       String  @id @default(cuid())
  name     String // "Solomillo Vaca Rubia - Prov A"
  
  // Legacy string field (to be tracked/migrated)
  supplier String?

  // New Relation to canonical Supplier entity
  supplierEntity   Supplier? @relation(fields: [supplierId], references: [id])
  supplierId String?

  // Relation to Canonical Ingredient
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  ingredientId String?

  // New Relation to canonical MasterProduct
  masterProduct   MasterProduct? @relation(fields: [masterProductId], references: [id])
  masterProductId String?

  price    Float // Price per unit (e.g. 18.00)
  unit     String // KG, BOX, PACK
  quantityPerUnit Float? // e.g. 4 (if unit is PACK), or 15 (if unit is BOX and it's 15kg)
  sapiensWorld String? // Reino Animal, Reino Vegetal, Reino Fungi, Mundo Mineral

  transformations Transformation[]

  // Storage Location
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id])
  storageLocationId String?

  purchaseOrderLines PurchaseOrderLine[] @relation("PurchaseOrderLineProduct")

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  RecipeItem RecipeItem[]
}

// La regla de conversión (Transformation/Despiece)
model Transformation {
  id   String @id @default(cuid())
  name String // "Limpieza Standard"

  // Input (Source)
  sourceProduct   SupplierProduct @relation(fields: [sourceProductId], references: [id])
  sourceProductId String

  // Test data
  testQuantity Float // Input quantity used in the yield test (e.g., 10 KG)
  testUnit     String @default("KG") // Unit used in the test (KG, L, UD...)

  // Outputs (Destinations)
  outputs TransformationOutput[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransformationOutput {
  id String @id @default(cuid())

  transformation   Transformation @relation(fields: [transformationId], references: [id], onDelete: Cascade)
  transformationId String

  // Link to the Ingredient that is generated
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String // Removed @unique to allow multiple transformations to produce the same ingredient

  weight         Float // Actual output weight from the test (e.g., 6.5 KG)
  percentage     Float // e.g. 60.0 (60%) yield of the source weight
  costAllocation Float // e.g. 1.2 (Allocates 1.2x cost per kg relative to source avg)
}

// -----------------------------------------------------------------------------

// Formatos de compra (e.g. "Saco 25kg")
model PurchaseFormat {
  id                String @id @default(cuid())
  name              String
  quantityPerFormat Float // e.g. 25
  formatUnit        String // e.g. KG
  price             Float // Price for the whole format (e.g. 25 EUR)

  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 3. Recipes (Elaboraciones)
model Recipe {
  id            String  @id @default(cuid())
  name          String
  version       Int     @default(1)
  yieldQuantity Float // e.g. 10 (Servings) or 2 (KG)
  yieldUnit     String? // Optional unit
  instructions  String?
  isSubRecipe   Boolean @default(false)

  category        String        @default("ELABORACION_FINAL") // PRODUCTO_NO_ELABORADO, ELABORACION_INTERMEDIA, ELABORACION_FINAL
  classification  String?       // Old "Category" (e.g. Postres, Salsas)
  packaging String?
  portions  Int?
  prepTime  Int? // Minutes
  cookTime  Int? // Minutes

  // Diet & Allergens
  isGlutenFree  Boolean @default(false)
  isVegan       Boolean @default(false)
  isVegetarian  Boolean @default(false)
  isLactoseFree Boolean @default(false)
  allergens     String?

  steps RecipeStep[]

  items RecipeItem[] @relation("RecipeToItems")

  // Inverse relation: This recipe can be used as an item in other recipes (if it's a sub-recipe)
  usedInRecipes RecipeItem[] @relation("SubRecipeRef")

  // For Events
  menuItems EventMenuItem[]

  // For Tasks (Production tasks)
  tasks Task[]

  // For Mise En Place
  miseEnPlaceTasks MiseEnPlaceTask[]

  // Inverse relation: This recipe used as a sub-recipe in steps
  usedInSteps RecipeStep[] @relation("SubRecipeStep")

  // Inverse relation: This recipe used as a sub-recipe in step ingredients
  usedInStepIngredients RecipeStepIngredient[]
  menuServiceItems      MenuServiceItem[]
  salesRecords          SalesRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User?   @relation("RecipeOwner", fields: [ownerId], references: [id])
}

model RecipeStep {
  id String @id @default(cuid())

  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  order       Int
  description String

  // Structured Data
  action    String? // CORTAR, DESPIEZAR, COCCION
  subAction String? // BRUNOISSE, FILETEAR, AL_VACIO

  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  ingredientId String?

  subRecipe    Recipe?     @relation("SubRecipeStep", fields: [subRecipeId], references: [id])
  subRecipeId  String?

  // New Relation: Multiple Ingredients/SubRecipes per step
  stepIngredients RecipeStepIngredient[]
}

model RecipeStepIngredient {
  id String @id @default(cuid())

  step      RecipeStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  stepId    String

  // Link to Ingredient
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  ingredientId String?

  // Link to SubRecipe
  subRecipe    Recipe?     @relation(fields: [subRecipeId], references: [id])
  subRecipeId  String?

  // Action per ingredient
  action    String?
  subAction String?
}

// Lines in a recipe (Ingredients or other Recipes)
model RecipeItem {
  id String @id @default(cuid())

  recipe   Recipe @relation("RecipeToItems", fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  type String // INGREDIENT, SUB_RECIPE

  // Link to Ingredient
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  ingredientId String?

  // Link to Recipe (Sub-recipe)
  subRecipe   Recipe? @relation("SubRecipeRef", fields: [subRecipeId], references: [id])
  subRecipeId String?

  quantityGross Float // Quantity needed before cleaning/prep
  quantityNet   Float? // Optional: Net quantity actually used
  unit          String

  // Link to a specific Supplier Product (Optional: to enforce a specific brand/provider)
  sourceProduct   SupplierProduct? @relation(fields: [sourceProductId], references: [id])
  sourceProductId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 4. Events
model Event {
  id           String   @id @default(cuid())
  name         String
  date         DateTime
  pax          Int // Number of guests
  safetyMargin Float    @default(1.1) // 1.1 = +10%
  status       String   @default("DRAFT") // DRAFT, CONFIRMED, COMPLETED

  menuItems EventMenuItem[]
  tasks     Task[]          @relation("EventTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User?   @relation("EventOwner", fields: [ownerId], references: [id])
}

model EventMenuItem {
  id      String @id @default(cuid())
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String

  recipe   Recipe @relation(fields: [recipeId], references: [id])
  recipeId String

  servingsOverride Int? // If different from Event PAX
}

// 5. Tasks
model Task {
  id          String  @id @default(cuid())
  title       String
  description String?

  assignedTo       User?   @relation("AssignedTasks", fields: [assignedToUserId], references: [id])
  assignedToUserId String?

  status String @default("PENDING") // PENDING, IN_PROGRESS, DONE, ISSUE
  issueReason String?

  plannedStart DateTime?
  plannedEnd   DateTime?
  realStart    DateTime?
  realEnd      DateTime?

  // Linking a task to a recipe production
  recipe         Recipe? @relation(fields: [recipeId], references: [id])
  recipeId       String?
  targetQuantity Float? // How much to produce
  unit           String? // KG, UD, etc.

  // Granular Metadata
  action    String? // CORTAR, DESPIEZAR, COCCION, etc.
  technique String? // BRUNOISSE, AL_VACIO, etc.

  // Many-to-Many Relationship with Events (for aggregation)
  events Event[] @relation("EventTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User?   @relation("TaskOwner", fields: [ownerId], references: [id])
}

// 6. Audit & Logs
model AuditLog {
  id        String @id @default(cuid())
  tableName String
  recordId  String
  action    String // CREATE, UPDATE, DELETE

  changedBy       User?   @relation(fields: [changedByUserId], references: [id])
  changedByUserId String?

  timestamp DateTime @default(now())
  changes   String? 
}

// 8. STORAGE & LOGISTICS (ALMACEN)
enum StorageZone {
  COCINA
  ALMACEN_SECO
  CAMARA_FRIA
  CONGELACION
}

model StorageLocation {
  id          String      @id @default(cuid())
  name        String      // "Timbre 1", "Estantería A"
  zone        StorageZone
  
  description String?
  
  // Hierarchy: Area -> Shelf -> Position
  parentId    String?
  parent      StorageLocation? @relation("LocationHierarchy", fields: [parentId], references: [id])
  children    StorageLocation[] @relation("LocationHierarchy")

  // Products stored here
  storedIngredients Ingredient[]
  storedProducts    SupplierProduct[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String?
  owner   User?   @relation("StorageOwner", fields: [ownerId], references: [id])
}

// 9. MISE EN PLACE
enum GastronormSize {
  GN_1_1
  GN_1_2
  GN_1_3
  GN_1_4
  GN_1_6
  GN_1_9
}

enum GastronormDepth {
  D_20
  D_40
  D_65
  D_100
  D_150
  D_200
}

enum StationType {
  FRIO
  CALIENTE
  PASE
}

model MiseEnPlaceTask {
  id          String   @id @default(cuid())
  name        String   // "Corte de Cebolla" or "Salsas Mesa 1"
  station     StationType
  
  // Linked Recipe (Optional, e.g. "Salsa Tomate")
  recipe      Recipe?  @relation(fields: [recipeId], references: [id])
  recipeId    String?

  typicalVolume String? // "2KG" or "10L" text for now, or float
  
  // Recommended GN
  recommendedGhSize  GastronormSize
  recommendedGhDepth GastronormDepth
  
  refillRequired Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String?
  owner   User?   @relation("MiseEnPlaceOwner", fields: [ownerId], references: [id])
}

// 10. SALES DATA (SMART SHOPPING)
model SalesData {
  id          String   @id @default(cuid())
  date        DateTime
  productName String
  quantity    Float    // Quantity sold
  amount      Float?   // Revenue
  
  source      String   @default("AGORA") // AGORA, MANUAL, ETC

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 11. TIMBRE CONFIGURATION & MISE EN PLACE
model Timbre {
  id          String   @id @default(cuid())
  name        String   // e.g., "Timbre Zona Caliente"
  shelves     Shelf[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Shelf {
  id          String   @id @default(cuid())
  timbreId    String
  timbre      Timbre   @relation(fields: [timbreId], references: [id], onDelete: Cascade)
  position    Int      // 1 (top) to N (bottom)
  height      Int      // Available height in mm (availableHeight)
  partitions  Partition[]
}

model Partition {
  id            String   @id @default(cuid())
  name          String
  
  // Characteristics
  type          String   // PartitionType: "topping", "garnish", "medium", "large", "production"
  volumeLevel   String   // VolumeLevel: "bajo", "medio", "alto"
  serviceRhythm String   // ServiceRhythm: "bajo", "medio", "alto"
  
  // Calculated/Assigned values
  shelfId       String?
  shelf         Shelf?   @relation(fields: [shelfId], references: [id])
  assignedGN    String?  // e.g., "1/6", "1/3"
  assignedDepth Int?     // e.g., 65, 100, 150
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 6. Daily Menu & POS Integration
model MenuService {
  id     String   @id @default(cuid())
  name   String // e.g., "Almuerzo", "Cena"
  startDate   DateTime
  endDate     DateTime
  status String   @default("PLANNED") // PLANNED, ACTIVE, COMPLETED

  items MenuServiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   User?   @relation("MenuServiceOwner", fields: [ownerId], references: [id])
}

model MenuServiceItem {
  id            String      @id @default(cuid())
  menuServiceId String
  menuService   MenuService @relation(fields: [menuServiceId], references: [id], onDelete: Cascade)

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  estimatedPax Int  @default(0)
  realPax      Int? // Actual sales from POS
}

model POSIntegration {
  id        String @id @default(cuid())
  provider  String // e.g., "REVO", "SQUARE"
  apiKey    String
  apiSecret String?
  baseUrl   String?
  isActive  Boolean   @default(true)
  lastSync  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalesRecord {
  id           String   @id @default(cuid())
  date         DateTime
  recipeId     String
  recipe       Recipe   @relation(fields: [recipeId], references: [id])
  quantitySold Int
  totalRevenue Float

  source String // e.g., "REVO"

  createdAt DateTime @default(now())
}

// 12. OBRADOR MODULE

model ObradorConfig {
  id                String   @id @default("default")
  businessName      String?  // Nombre comercial
  companyName       String?  // Razón social
  nif               String?
  address           String?
  phone             String?
  email             String?
  activity          String?  // restaurante, obrador, elaboración propia, etc.
  registryType      String?  // Registro autonómico, RGSEAA, etc.
  registryNumber    String?
  requestDate       DateTime?
  resolutionDate    DateTime?
  status            String   @default("no_iniciado") // no_iniciado, solicitado, aprobado, etc.
  region            String?  // Comunidad autónoma
  
  ownerId           String?
  owner             User?    @relation("ObradorConfigOwner", fields: [ownerId], references: [id])
  
  updatedAt         DateTime @updatedAt
}

model ObradorProduct {
  id                  String   @id @default(cuid())
  name                String
  category            String   // embutido, carne fresca, carne picada, pan, hamburguesa, otro
  legalDenomination   String?
  commercialDescription String?
  conservationType    String?  // refrigerado, congelado, ambiente
  recommendedTemp     String?
  shelfLifeDays       Int?
  requiresCooking     Boolean  @default(true)
  usageInstructions   String?
  saleFormat          String?  // unidad, peso, bandeja, etc.
  defaultWeight       Float?
  isActive            Boolean  @default(true)
  imageUrl            String?
  labelTemplate       String   @default("100x70")

  // Nutritional Info
  energyKj            Float?
  energyKcal          Float?
  fat                 Float?
  saturatedFat        Float?
  carbs               Float?
  sugars              Float?
  protein             Float?
  salt                Float?
  nutritionalStatus   String   @default("pendiente") // pendiente, verificado

  recipe              ObradorRecipe?
  productionBatches   ObradorProductionBatch[]

  ownerId             String?
  owner               User?    @relation("ObradorProductOwner", fields: [ownerId], references: [id])

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ObradorRecipe {
  id            String   @id @default(cuid())
  productId     String   @unique
  product       ObradorProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  ingredients   ObradorRecipeIngredient[]
  
  totalCost     Float?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ObradorRecipeIngredient {
  id            String   @id @default(cuid())
  recipeId      String
  recipe        ObradorRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  
  name          String
  percentage    Float?
  quantity      Float?
  unit          String?
  allergens     String? // Comma separated list of 14 main allergens
  isAdditive    Boolean  @default(false)
  
  supplierId    String?
  
  cost          Float?

  createdAt     DateTime @default(now())
}

model ObradorRawMaterialEntry {
  id                String   @id @default(cuid())
  
  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id])
  supplierName      String // Fallback or manually entered
  
  productName       String
  supplierBatch     String?
  receptionDate     DateTime @default(now())
  expiryDate        DateTime?
  quantityReceived  Float
  unit              String
  receptionTemp     Float?
  visualStatus      String?  // Correcto, Incorrecto
  documentUrl       String?  // Factura/Albarán
  isApto            Boolean  @default(true)
  observations      String?

  batchIngredients  ObradorBatchIngredient[]

  ownerId           String?
  owner             User?    @relation("ObradorIntakeOwner", fields: [ownerId], references: [id])

  createdAt         DateTime @default(now())
}

model ObradorProductionBatch {
  id                String   @id @default(cuid())
  batchCode         String   @unique // L-YYYYMMDD-PROD-NNN
  
  productId         String
  product           ObradorProduct @relation(fields: [productId], references: [id])
  
  productionDate    DateTime @default(now())
  expiryDate        DateTime
  quantityProduced  Float
  unit              String
  
  operatorId        String?
  operatorName      String? // Fallback if user is deleted
  
  wasteQuantity     Float?
  observations      String?
  status            String   @default("abierto") // abierto, cerrado, bloqueado, retirado

  usedMaterials     ObradorBatchIngredient[]
  sales             ObradorSale[]

  ownerId           String?
  owner             User?    @relation("ObradorBatchOwner", fields: [ownerId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ObradorBatchIngredient {
  id                String   @id @default(cuid())
  
  productionBatchId String
  productionBatch   ObradorProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  
  rawMaterialEntryId String
  rawMaterialEntry   ObradorRawMaterialEntry @relation(fields: [rawMaterialEntryId], references: [id])
  
  quantityUsed      Float?

  createdAt         DateTime @default(now())
}

model ObradorCustomer {
  id                String   @id @default(cuid())
  name              String
  nif               String?
  address           String?
  phone             String?
  email             String?
  customerType      String?  // Consumidor final, Minorista, Online, Profesional
  
  sales             ObradorSale[]

  ownerId           String?
  owner             User?    @relation("ObradorCustomerOwner", fields: [ownerId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ObradorSale {
  id                String   @id @default(cuid())
  
  customerId        String
  customer          ObradorCustomer @relation(fields: [customerId], references: [id])
  
  batchId           String
  batch             ObradorProductionBatch @relation(fields: [batchId], references: [id])
  
  quantitySold      Float
  saleDate          DateTime @default(now())
  documentUrl       String?

  createdAt         DateTime @default(now())
}

model ObradorTemperatureLog {
  id                String   @id @default(cuid())
  equipmentName     String   // Cámara 1, Obrador, etc.
  temperature       Float
  logDate           DateTime @default(now())
  operatorName      String
  hasIncidence      Boolean  @default(false)
  correctiveAction  String?

  ownerId           String?
  owner             User?    @relation("ObradorTempOwner", fields: [ownerId], references: [id])

  createdAt         DateTime @default(now())
}

model ObradorCleaningTask {
  id                String   @id @default(cuid())
  area              String
  task              String
  frequency         String   // Diaria, Semanal, Mensual
  
  logs              ObradorCleaningLog[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ObradorCleaningLog {
  id                String   @id @default(cuid())
  
  taskId            String
  task              ObradorCleaningTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  logDate           DateTime @default(now())
  operatorName      String
  status            String   // Realizado, No realizado
  observations      String?
  signatureUrl      String?

  createdAt         DateTime @default(now())
}

model ObradorIncident {
  id                String   @id @default(cuid())
  type              String
  description       String
  affectedBatchId   String?
  incidentDate      DateTime @default(now())
  correctiveAction  String?
  operatorName      String
  status            String   @default("abierto") // abierto, cerrado
  documentUrl       String?

  ownerId           String?
  owner             User?    @relation("ObradorIncidentOwner", fields: [ownerId], references: [id])

  createdAt         DateTime @default(now())
}

model ObradorSanitaryDocument {
  id                String   @id @default(cuid())
  title             String
  category          String   // Registro, APPCC, Limpieza, Plagas, Formación, Fichas, Albaranes, Facturas, Certificados, Incidencias, Retiradas, Inspecciones
  fileUrl           String
  expiryDate        DateTime?
  associatedId      String?  // Optional link to product, supplier or batch
  
  ownerId           String?
  owner             User?    @relation("ObradorDocOwner", fields: [ownerId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================================================
// 9. LOCATIONS (multi-local bajo un mismo admin/cliente)
// ============================================================================
model Location {
  id        String   @id @default(cuid())
  name      String
  shortCode String?
  address   String?
  isActive  Boolean  @default(true)

  ownerId String
  owner   User   @relation("LocationOwner", fields: [ownerId], references: [id])

  members        User[]              @relation("LocationMembers")
  templates      ChecklistTemplate[] @relation("ChecklistTemplateLocation")
  schedules      ChecklistSchedule[] @relation("ChecklistScheduleLocation")
  communications Communication[]     @relation("CommunicationLocation")
  clockIns        ClockIn[]           @relation("ClockInLocation")
  shifts          Shift[]             @relation("ShiftLocation")
  productLabels   ProductLabel[]      @relation("ProductLabelLocation")
  cashClosings    CashClosing[]       @relation("CashClosingLocation")
  financialEntries FinancialEntry[]   @relation("FinancialEntryLocation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// 10. CHECKLISTS (patrón yurest: Plantilla → Programación → Instancia → Respuesta)
// ============================================================================

enum ChecklistFieldType {
  TITLE
  CHECK
  TEXT
  YES_NO
  RATING_1_10
}

enum PhotoRequirement {
  NONE
  OPTIONAL
  REQUIRED
}

enum Frequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum InstanceStatus {
  PENDING
  IN_PROGRESS
  DONE
  CLOSED_AUTO
  INCIDENT
}

model ChecklistTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  ownerId String
  owner   User   @relation("ChecklistTemplateOwner", fields: [ownerId], references: [id])

  // null = aplicable a todos los locales del owner
  locationId String?
  location   Location? @relation("ChecklistTemplateLocation", fields: [locationId], references: [id])

  fields    ChecklistField[]
  schedules ChecklistSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistField {
  id               String             @id @default(cuid())
  templateId       String
  template         ChecklistTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order            Int
  type             ChecklistFieldType
  name             String
  description      String?
  exampleImageUrl  String?
  photoRequirement PhotoRequirement   @default(NONE)

  responses ChecklistResponse[]
}

model ChecklistSchedule {
  id                 String    @id @default(cuid())
  templateId         String
  template           ChecklistTemplate @relation(fields: [templateId], references: [id])

  locationId String
  location   Location @relation("ChecklistScheduleLocation", fields: [locationId], references: [id])

  frequency          Frequency
  startDate          DateTime
  endDate            DateTime?
  executionStartTime String     // "HH:MM"
  executionEndTime   String     // "HH:MM"
  excludeWeekdays    Int[]      @default([])  // 0=domingo … 6=sábado
  autoClose          Boolean    @default(false)
  pinned             Boolean    @default(false)

  // Asignación (string[] de User ids para flexibilidad inicial)
  performerUserIds   String[]   @default([])
  supervisorUserIds  String[]   @default([])
  followerUserIds    String[]   @default([])
  performerRoles     String[]   @default([])
  supervisorRoles    String[]   @default([])
  followerRoles      String[]   @default([])

  ownerId String
  owner   User   @relation("ChecklistScheduleOwner", fields: [ownerId], references: [id])

  instances ChecklistInstance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistInstance {
  id         String   @id @default(cuid())
  scheduleId String
  schedule   ChecklistSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  dueDate    DateTime

  status         InstanceStatus @default(PENDING)
  openedAt       DateTime?
  closedAt       DateTime?
  closedByUserId String?
  closedBy       User?    @relation("ChecklistInstanceClosedBy", fields: [closedByUserId], references: [id])
  scoreAvg       Float?

  responses ChecklistResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scheduleId, dueDate])
}

// ============================================================================
// 11. COMUNICACIONES (averías, avisos, eventos, reuniones — patrón yurest)
// ============================================================================

enum CommunicationType {
  BREAKDOWN  // Avería
  NOTICE     // Aviso
  EVENT      // Evento
  MEETING    // Reunión
  TASK       // Tarea programada (Comunicación > Programadas)
  LIST       // Listas
}

enum CommunicationStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model Communication {
  id          String              @id @default(cuid())
  type        CommunicationType
  title       String
  description String?
  status      CommunicationStatus @default(OPEN)

  // Multi-tenancy
  ownerId String
  owner   User   @relation("CommunicationOwner", fields: [ownerId], references: [id])

  // Local opcional
  locationId String?
  location   Location? @relation("CommunicationLocation", fields: [locationId], references: [id])

  // Autor
  authorId String
  author   User   @relation("CommunicationAuthor", fields: [authorId], references: [id])

  // Asignados / seguidores (arrays simples como en Schedule)
  assigneeIds String[] @default([])
  followerIds String[] @default([])

  // Programación opcional (para type=TASK)
  scheduledAt DateTime?
  closedAt    DateTime?

  // Fotos / adjuntos (URLs CDN)
  photoUrls String[] @default([])

  comments CommunicationComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunicationComment {
  id              String        @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("CommunicationCommentAuthor", fields: [authorId], references: [id])

  body   String
  photos String[] @default([])

  createdAt DateTime @default(now())
}

model ChecklistResponse {
  id         String @id @default(cuid())
  instanceId String
  instance   ChecklistInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  fieldId    String
  field      ChecklistField    @relation(fields: [fieldId], references: [id])

  valueText    String?
  valueBool    Boolean?
  valueRating  Int?
  photoUrl     String?
  photoKey     String?
  isIncident   Boolean  @default(false)
  incidentNote String?

  answeredByUserId String?
  answeredBy       User?   @relation("ChecklistResponseAnsweredBy", fields: [answeredByUserId], references: [id])
  answeredAt       DateTime?

  supervisedByUserId String?
  supervisedBy       User?    @relation("ChecklistResponseSupervisedBy", fields: [supervisedByUserId], references: [id])
  supervisedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instanceId, fieldId])
}

// ============================================================================
// 12. FICHAJE / CLOCK-IN (patrón yurest)
// ============================================================================

model ClockIn {
  id String @id @default(cuid())

  // Multi-tenancy
  ownerId String
  owner   User   @relation("ClockInOwner", fields: [ownerId], references: [id])

  // Trabajador que ficha
  workerId String
  worker   User   @relation("ClockInWorker", fields: [workerId], references: [id])

  // Local opcional donde se realiza la jornada
  locationId String?
  location   Location? @relation("ClockInLocation", fields: [locationId], references: [id])

  // Entrada / salida
  startAt        DateTime
  endAt          DateTime?
  startPhotoUrl  String?
  endPhotoUrl    String?
  startSignature String?    // base64 SVG/PNG opcional
  endSignature   String?
  note           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, workerId, startAt])
  @@index([ownerId, locationId, startAt])
}

// ============================================================================
// 13. SOLICITUDES (vacaciones, ausencias, cambios de turno) — patrón yurest
// ============================================================================

enum EmployeeRequestType {
  HOLIDAY      // vacaciones
  SICK_LEAVE   // baja médica
  PERSONAL     // asuntos propios
  SHIFT_SWAP   // cambio de turno
  OTHER
}

enum EmployeeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model EmployeeRequest {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation("EmployeeRequestOwner", fields: [ownerId], references: [id])

  workerId String
  worker   User   @relation("EmployeeRequestWorker", fields: [workerId], references: [id])

  type   EmployeeRequestType
  status EmployeeRequestStatus @default(PENDING)

  startDate DateTime  // fecha inicio (para vacaciones y bajas; para SHIFT_SWAP solo la fecha del cambio)
  endDate   DateTime? // null si es un solo día

  reason   String?
  decision String? // motivo aceptado/rechazado por el admin

  resolverUserId String?
  resolver       User?   @relation("EmployeeRequestResolver", fields: [resolverUserId], references: [id])
  resolvedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, status, startDate])
  @@index([ownerId, workerId, startDate])
}

// ============================================================================
// 14. TURNOS / HORARIOS (yurest schedule)
// ============================================================================

model Shift {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation("ShiftOwner", fields: [ownerId], references: [id])

  workerId String
  worker   User   @relation("ShiftWorker", fields: [workerId], references: [id])

  locationId String?
  location   Location? @relation("ShiftLocation", fields: [locationId], references: [id])

  date          DateTime  // día del turno (UTC, hora 00:00)
  startTime     String    // "08:00"
  endTime       String    // "16:00"
  breakMinutes  Int       @default(0)
  note          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, date])
  @@index([ownerId, workerId, date])
}

// ============================================================================
// 15. PEDIDOS A PROVEEDORES + ALBARANES (yurest order + delivery-note)
// ============================================================================

enum PurchaseOrderStatus {
  DRAFT       // borrador editable
  SENT        // enviado al proveedor
  RECEIVED    // mercancía recibida (parcial o total)
  CLOSED      // cerrado, no se aceptan cambios
  CANCELLED
}

model PurchaseOrder {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation("PurchaseOrderOwner", fields: [ownerId], references: [id])

  createdByUserId String?
  createdBy       User?   @relation("PurchaseOrderCreator", fields: [createdByUserId], references: [id])

  supplierId String
  supplier   Supplier @relation("PurchaseOrderSupplier", fields: [supplierId], references: [id])

  status PurchaseOrderStatus @default(DRAFT)

  reference     String?  // número/referencia del pedido
  expectedDate  DateTime?
  sentAt        DateTime?
  closedAt      DateTime?
  notes         String?

  lines         PurchaseOrderLine[]
  deliveryNotes DeliveryNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, status])
  @@index([ownerId, supplierId, createdAt])
}

model PurchaseOrderLine {
  id String @id @default(cuid())

  orderId String
  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Producto puede ser de catálogo (SupplierProduct) o ad-hoc por texto
  supplierProductId String?
  supplierProduct   SupplierProduct? @relation("PurchaseOrderLineProduct", fields: [supplierProductId], references: [id])

  productName String  // siempre rellenado para no perder histórico
  unit        String  // KG, UD, L, BOX...
  quantity    Float
  unitPrice   Float?  // opcional

  // Lo que finalmente se recibió (puede ser distinto)
  receivedQuantity Float?  @default(0)
}

model DeliveryNote {
  id String @id @default(cuid())

  orderId String
  order   PurchaseOrder @relation(fields: [orderId], references: [id])

  receivedByUserId String?
  receivedBy       User?   @relation("DeliveryNoteReceiver", fields: [receivedByUserId], references: [id])

  receivedAt DateTime @default(now())

  photoUrls    String[]  @default([])   // fotos del albarán/mercancía
  signatureSvg String?                  // firma del receptor
  note         String?

  // Opcionalmente las líneas concretas recibidas (si parcial)
  receivedLines Json?  // [{orderLineId, qty}]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// 16. ETIQUETAS DE PRODUCTOS (yurest labeled-store) — trazabilidad alimentaria
// ============================================================================

enum LabelStorageMode {
  AMBIENT
  REFRIGERATED
  FROZEN
}

model ProductLabel {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation("ProductLabelOwner", fields: [ownerId], references: [id])

  createdByUserId String?
  createdBy       User?   @relation("ProductLabelCreator", fields: [createdByUserId], references: [id])

  locationId String?
  location   Location? @relation("ProductLabelLocation", fields: [locationId], references: [id])

  productName    String
  lotNumber      String?
  productionDate DateTime
  expiryDate     DateTime?
  storageMode    LabelStorageMode @default(REFRIGERATED)
  allergens      String[]  @default([])
  ingredients    String?
  weight         String?    // "500 g", "2 kg", etc.
  note           String?
  photoUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, productionDate])
  @@index([ownerId, locationId, productionDate])
}

// ============================================================================
// 17. CIERRES DE CAJA (yurest cash-closing)
// ============================================================================

enum CashClosingShift {
  MORNING   // turno comida
  EVENING   // turno cena
  FULL_DAY  // único cierre del día
}

model CashClosing {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation("CashClosingOwner", fields: [ownerId], references: [id])

  locationId String?
  location   Location? @relation("CashClosingLocation", fields: [locationId], references: [id])

  closedByUserId String?
  closedBy       User?   @relation("CashClosingCloser", fields: [closedByUserId], references: [id])

  date  DateTime          // día del cierre (UTC 00:00)
  shift CashClosingShift  @default(FULL_DAY)

  // Importes en EUR (Float; ya hay convención en el schema actual)
  cashAmount         Float    @default(0)  // efectivo declarado
  expectedCashAmount Float    @default(0)  // efectivo esperado (TPV o ventas brutas)
  cardAmount         Float    @default(0)
  otherAmount        Float    @default(0)  // bizum, transferencia, etc.
  tips               Float    @default(0)

  // diferencia se deriva (cash - expectedCash) pero también persistimos por simplicidad
  diff Float @default(0)

  notes    String?
  photoUrl String?

  isLocked Boolean  @default(false)  // una vez bloqueado no se edita

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, locationId, date, shift])
  @@index([ownerId, date])
}

// ============================================================================
// 18. FINANZAS (yurest income / expenses / payments / EBITDA)
// ============================================================================

enum FinancialEntryType {
  INCOME             // ingresos
  EXPENSE_OPERATING  // gastos operativos (cocina, materia prima ad-hoc, luz, agua, alquiler)
  EXPENSE_PAYROLL    // nóminas y SS
  EXPENSE_SUPPLIER   // pago a proveedores (puede venir de PurchaseOrder)
  EXPENSE_OTHER      // otros gastos (formación, marketing…)
}

model FinancialEntry {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation("FinancialEntryOwner", fields: [ownerId], references: [id])

  createdByUserId String?
  createdBy       User?   @relation("FinancialEntryCreator", fields: [createdByUserId], references: [id])

  locationId String?
  location   Location? @relation("FinancialEntryLocation", fields: [locationId], references: [id])

  type     FinancialEntryType
  category String   // "Alquiler", "Luz", "Verduras", "Nómina María", etc.
  date     DateTime // fecha del apunte (UTC 00:00)
  amount   Float    // siempre positivo; el signo lo da el type
  description String?
  receiptUrl  String?  // foto/escan de factura

  // Trazabilidad opcional con otros modelos
  cashClosingId   String? // si proviene de un cierre de caja
  purchaseOrderId String? // si proviene de un pedido

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, type, date])
  @@index([ownerId, locationId, date])
}
