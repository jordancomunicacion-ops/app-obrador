  startDate       DateTime
  endDate         DateTime?
  excludeWeekdays Int[]     @default([]) // 0=domingo … 6=sábado
  executionTime   String? // "HH:MM" hora planificada de la tarea generada

  // Asignación por defecto de las tareas generadas (reasignable luego).
  defaultAssigneeUserId String?
  defaultAssignee       User?   @relation("ProductionRoutineAssignee", fields: [defaultAssigneeUserId], references: [id])

