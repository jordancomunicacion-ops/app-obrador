// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Users & Roles
model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        String   @default("USER") // SUPERADMIN (propietario de plataforma, cross-tenant), ADMIN (cliente/tenant), USER (empleado), VET
  approved    Boolean  @default(false)
  permissions String[] @default([])

  // Extended Profile Fields (Matches App Ganadera)
  firstName String?
  lastName  String?
  dni       String?
  phone     String?
  jobTitle  String?
  dob       DateTime?
  image     String? // URL to profile image

  // Worker/Admin Relationship
  // If this user is a WORKER, who is their ADMIN?
  adminId String?
  admin   User?   @relation("AdminWorkers", fields: [adminId], references: [id])
  workers User[]  @relation("AdminWorkers") // If this user is ADMIN, these are their workers

  tasks     Task[]     @relation("AssignedTasks")
  auditLogs AuditLog[]

  // Ciclos de producción recurrentes (propios y asignados por defecto)
  assignedProductionRoutines ProductionRoutine[] @relation("ProductionRoutineAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-Tenancy Relations (Owned Data)

  // Obrador Relations

  // Empresas (empleador legal: razón social + NIF) bajo una misma cuenta de cliente

  // Empleo: contratos de esta persona (uno por empresa empleadora)
  employments Employment[] @relation("UserEmployments")

  // Locales (multi-location bajo un mismo admin)
  locationId String?
  location   Location? @relation("LocationMembers", fields: [locationId], references: [id])

  // Checklists (patrón yurest)
  closedChecklistInstances     ChecklistInstance[] @relation("ChecklistInstanceClosedBy")
  assignedChecklistInstances   ChecklistInstance[] @relation("ChecklistInstanceAssignee")
  answeredChecklistResponses   ChecklistResponse[] @relation("ChecklistResponseAnsweredBy")
  supervisedChecklistResponses ChecklistResponse[] @relation("ChecklistResponseSupervisedBy")

  // Motor de tareas único (Fase 3, Frente B)
  assignedTaskInstances   TaskInstance[] @relation("TaskInstanceAssignee")
  closedTaskInstances     TaskInstance[] @relation("TaskInstanceClosedBy")
  answeredTaskResponses   TaskResponse[] @relation("TaskResponseAnsweredBy")
  supervisedTaskResponses TaskResponse[] @relation("TaskResponseSupervisedBy")

  // Comunicaciones (averías, avisos, eventos, reuniones)
  authoredCommunications Communication[]        @relation("CommunicationAuthor")
  authoredCommComments   CommunicationComment[] @relation("CommunicationCommentAuthor")

  // Pedidos y albaranes
  createdPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreator")
  receivedDeliveryNotes DeliveryNote[]  @relation("DeliveryNoteReceiver")

  // Etiquetas
  createdProductLabels ProductLabel[] @relation("ProductLabelCreator")

  // Clientes (núcleo, Frente A)

  // Push notifications
  pushSubscriptions PushSubscription[]

  // Empresa(s) de la que el usuario es dueño cuando estaba como ADMIN en el
  // modelo antiguo (`ownerId` apuntaba al User.id). Se mantiene para no romper
  // los 28 modelos legacy mientras coexiste con `businessId`. La gestión de
  // acceso real va por BusinessAccess (email + businessId).
}

// ===========================================================================
// Multi-tenant moderno (modelo CRM/reservas) — coexiste con `ownerId` legado
// ===========================================================================
//
// Business = el negocio/marca/cliente final (lo que el super admin gestiona).
// BusinessAccess = quién entra a qué negocio y con qué permisos (granular).
//
// Identificación del super admin: comparación de email contra
// PLATFORM_OWNER_EMAIL en lib/auth/platform.ts. Si eres ese email, ves todo y
// puedes crear/eliminar negocios y conceder accesos. El resto solo ve los
// negocios donde tiene una fila en BusinessAccess.
//
// Esquema clonado del CRM (model WebSite + WebSiteAccess) para que ambas apps
// hablen el mismo lenguaje. Los flags `canView*` mapean a los grupos del
// sidebar (apps/web/app/ui/dashboard/nav-links.ts).
model Business {
  id         String  @id @default(uuid())
  name       String
  domain     String? @unique // opcional: dominio o slug identificador
  logoUrl    String?
  faviconUrl String?
  timezone   String  @default("Europe/Madrid")
  currency   String  @default("EUR")

  // Relaciones inversas a modelos legacy con `businessId` (Fase 2).
  appConfigs               AppConfig[]               @relation("AppConfigBusiness")
  ingredients              Ingredient[]              @relation("IngredientBusiness")
  customers                Customer[]                @relation("CustomerBusiness")
  suppliers                Supplier[]                @relation("SupplierBusiness")
  recipes                  Recipe[]                  @relation("RecipeBusiness")
  events                   Event[]                   @relation("EventBusiness")
  tasks                    Task[]                    @relation("TaskBusiness")
  productionRoutines       ProductionRoutine[]       @relation("ProductionRoutineBusiness")
  storageLocations         StorageLocation[]         @relation("StorageBusiness")
  miseEnPlaceTasks         MiseEnPlaceTask[]         @relation("MiseEnPlaceBusiness")
  menuServices             MenuService[]             @relation("MenuServiceBusiness")
  obradorConfigs           ObradorConfig[]           @relation("ObradorConfigBusiness")
  obradorRawMaterialEntrys ObradorRawMaterialEntry[] @relation("ObradorIntakeBusiness")
  obradorProductionBatchs  ObradorProductionBatch[]  @relation("ObradorBatchBusiness")
  obradorTemperatureLogs   ObradorTemperatureLog[]   @relation("ObradorTempBusiness")
  obradorIncidents         ObradorIncident[]         @relation("ObradorIncidentBusiness")
  obradorSanitaryDocuments ObradorSanitaryDocument[] @relation("ObradorDocBusiness")
  empresas                 Empresa[]                 @relation("EmpresaBusiness")
  locations                Location[]                @relation("LocationBusiness")
  checklistTemplates       ChecklistTemplate[]       @relation("ChecklistTemplateBusiness")
  checklistSchedules       ChecklistSchedule[]       @relation("ChecklistScheduleBusiness")
  communications           Communication[]           @relation("CommunicationBusiness")
  taskDefinitions          TaskDefinition[]          @relation("TaskDefinitionBusiness")
  taskSchedules            TaskSchedule[]            @relation("TaskScheduleBusiness")
  taskInstances            TaskInstance[]            @relation("TaskInstanceBusiness")
  purchaseOrders           PurchaseOrder[]           @relation("PurchaseOrderBusiness")
  productLabels            ProductLabel[]            @relation("ProductLabelBusiness")
  onlineOrders             OnlineOrder[]             @relation("OnlineOrderBusiness")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 7. App Configuration
model AppConfig {
  id      String  @id @default("default")
  logoUrl String? // URL to app logo

  updatedAt DateTime @updatedAt

  businessId String?
  business   Business? @relation("AppConfigBusiness", fields: [businessId], references: [id], onDelete: SetNull)
}

model RecipeCategory {
  id   String @id @default(cuid())
  name String @unique

  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipePackaging {
  id   String @id @default(cuid())
  name String @unique
  type String @default("ENVASE") // ENVASE, MOLDE

  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Ingredients (Productos)
model Ingredient {
  id            String  @id @default(cuid())
  name          String
  category      String?
  pricingUnit   String  @default("KG") // KG, G, L, ML, UD
  pricePerUnit  Float // e.g., 10.50 (Euros)
  yieldPercent  Float   @default(100.0) // 100% means no loss. 80% means 20% loss.
  allergens     String? // SQLite does not support JSON well in standard prisma, usually String or serialized. Wait, Prisma supports JSON in SQLite?
  // "The Json type is supported...". Let's verify.
  allergensJson String? // Store as JSON string explicitly to be safe or use Bytes. 
  // Actually Prisma supports generic Json on SQLite since v3. I will try keeping Json type IF validation allows it.
  // If validation fails for JSON, I will switch to String.
  // Docs say: "SQLite doesn't support JSON type natively but Prisma polyfills it".
  // allergens       Json? // Retrying Json? The validation error before was about ENUMS.

  supplierId String?

  purchaseFormats PurchaseFormat[]
  recipeItems     RecipeItem[]
  recipeSteps     RecipeStep[]

  // New Relation: Ingredient comes from a Transformation Output
  transformationOutputs TransformationOutput[]

  // New Relation: Ingredient variants (SupplierProducts)
  supplierProducts SupplierProduct[]

  // New Relation: Ingredient used in StepIngredients
  recipeStepIngredients RecipeStepIngredient[]

  // Puente convergencia obrador → núcleo (Frente A, aditivo).
  obradorBatchIngredients ObradorBatchIngredient[] @relation("ObradorBatchIngredientToCore")

  // Storage Location
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id])
  storageLocationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String?
  business   Business? @relation("IngredientBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // Aislamiento por local (centro de trabajo). Nullable durante la transición.
  locationId String?
  location   Location? @relation("IngredientLocation", fields: [locationId], references: [id])

  @@index([locationId])
}

// -----------------------------------------------------------------------------
// NEW: PRODUCT & TRANSFORMATION ARCHITECTURE
// -----------------------------------------------------------------------------

// Canonical Product (e.g. "Aceite de Oliva")
model MasterProduct {
  id          String  @id @default(cuid())
  name        String
  category    String?
  description String?

  // Mundo/Reino (taxonomía Sapiens): aplica a TODOS los productos, comprados y
  // elaborados. En comprados se escribe también en cada SupplierProduct (legacy).
  sapiensWorld String?

  // Ficha única: un producto puede ser de cocina y/o de obrador (Fase 3, Frente A).
  isObrador Boolean @default(false)

  // --- Venta online (Ecommerce, aditivo) ---
  // Marca el producto como vendible en la tienda web. La web lee estos campos por
  // la API de integración del local. La ficha legal/alérgenos/nutrición se reutiliza
  // de `sanitaryInfo`; aquí solo va lo específico de la venta online.
  isSellableOnline  Boolean @default(false)
  salePrice         Float? // precio de venta al público (IVA incl.), en euros
  onlineDescription String? // descripción comercial para la tienda
  onlineImageUrl    String? // imagen de venta (CDN)

  // Pedidos online que incluyen este producto.
  onlineOrderItems OnlineOrderItem[]

  supplierProducts SupplierProduct[]

  // Sección sanitaria/nutricional/legal como extensión 1:1 (pestaña de la misma ficha).
  sanitaryInfo ProductSanitaryInfo?

  // Puentes de convergencia obrador → núcleo (aditivos, Frente A).
  obradorBatches ObradorProductionBatch[]  @relation("ObradorBatchToMaster")
  obradorIntakes ObradorRawMaterialEntry[] @relation("ObradorIntakeToMaster")

  // Etiquetas de venta generadas a partir de esta ficha.
  productLabels ProductLabel[] @relation("MasterProductLabels")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Aislamiento por local. Nullable durante la transición.
  locationId String?
  location   Location? @relation("MasterProductLocation", fields: [locationId], references: [id])

  @@index([locationId])
}

// Extensión 1:1 de MasterProduct con la info sanitaria/nutricional/legal
// (pestaña de la ficha única del producto, no un producto aparte).
model ProductSanitaryInfo {
  id              String        @id @default(cuid())
  masterProductId String        @unique
  masterProduct   MasterProduct @relation(fields: [masterProductId], references: [id], onDelete: Cascade)

  // Legal / conservación / uso
  legalDenomination     String?
  commercialDescription String?
  conservationType      String? // refrigerado, congelado, ambiente
  recommendedTemp       String?
  shelfLifeDays         Int?
  requiresCooking       Boolean @default(true)
  usageInstructions     String?
  saleFormat            String? // unidad, peso, bandeja, etc.
  defaultWeight         Float?
  labelTemplate         String  @default("100x70")
  allergens             String? // lista separada por comas de los 14 alérgenos
  ingredientsList       String? // composición en orden decreciente (para etiqueta)

  // Información nutricional
  energyKj          Float?
  energyKcal        Float?
  fat               Float?
  saturatedFat      Float?
  carbs             Float?
  sugars            Float?
  protein           Float?
  salt              Float?
  nutritionalStatus String @default("pendiente") // pendiente, verificado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Cliente del núcleo (reutilizable), acotado por local. Usado por obrador
// (puntos de venta / destinos) y disponible para el resto de la app (Frente A).
model Customer {
  id            String  @id @default(cuid())
  name          String
  nif           String?
  address       String?
  phone         String?
  email         String?
  contactPerson String? // persona de contacto
  customerType  String? // Consumidor final, Minorista, Online, Profesional

  businessId String?
  business   Business? @relation("CustomerBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // Aislamiento por local. Nullable durante la transición.
  locationId String?
  location   Location? @relation("CustomerLocation", fields: [locationId], references: [id])

  // Lotes de producción cuyo destino es este cliente / punto de venta.
  batches ObradorProductionBatch[] @relation("BatchToCustomer")

  // Pedidos online de este cliente (volcado del CRM web → obrador).
  onlineOrders OnlineOrder[] @relation("OnlineOrderCustomer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

// Vendor/Provider (e.g. "Makro", "Frutería Pepe")
model Supplier {
  id             String  @id @default(cuid())
  name           String  @unique
  nif            String?
  address        String?
  phone          String?
  contactInfo    String?
  email          String?
  contactPerson  String?
  productType    String?
  healthRegistry String?
  isActive       Boolean @default(true)

  products       SupplierProduct[]
  obradorIntakes ObradorRawMaterialEntry[]
  purchaseOrders PurchaseOrder[]           @relation("PurchaseOrderSupplier")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String?
  business   Business? @relation("SupplierBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // Aislamiento por local. Nullable durante la transición.
  locationId String?
  location   Location? @relation("SupplierLocation", fields: [locationId], references: [id])

  @@index([locationId])
}

// Lo que compras (SupplierProduct) - Specific variant from a supplier
model SupplierProduct {
  id   String @id @default(cuid())
  name String // "Solomillo Vaca Rubia - Prov A"

  // Legacy string field (to be tracked/migrated)
  supplier String?

  // New Relation to canonical Supplier entity
  supplierEntity Supplier? @relation(fields: [supplierId], references: [id])
  supplierId     String?

  // Relation to Canonical Ingredient
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  ingredientId String?

  // New Relation to canonical MasterProduct
  masterProduct   MasterProduct? @relation(fields: [masterProductId], references: [id])
  masterProductId String?

  price           Float // Price per unit (e.g. 18.00)
  unit            String // KG, BOX, PACK
  quantityPerUnit Float? // e.g. 4 (if unit is PACK), or 15 (if unit is BOX and it's 15kg)
  sapiensWorld    String? // Reino Animal, Reino Vegetal, Reino Fungi, Mundo Mineral

  transformations Transformation[]

  // Storage Location
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id])
  storageLocationId String?

  purchaseOrderLines PurchaseOrderLine[] @relation("PurchaseOrderLineProduct")

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  RecipeItem RecipeItem[]

  // Aislamiento por local. Nullable durante la transición.
  locationId String?
  location   Location? @relation("SupplierProductLocation", fields: [locationId], references: [id])

  @@index([locationId])
}

// La regla de conversión (Transformation/Despiece)
model Transformation {
  id   String @id @default(cuid())
  name String // "Limpieza Standard"

  // Input (Source)
  sourceProduct   SupplierProduct @relation(fields: [sourceProductId], references: [id])
  sourceProductId String

  // Test data
  testQuantity Float // Input quantity used in the yield test (e.g., 10 KG)
  testUnit     String @default("KG") // Unit used in the test (KG, L, UD...)

  // Outputs (Destinations)
  outputs TransformationOutput[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransformationOutput {
  id String @id @default(cuid())

  transformation   Transformation @relation(fields: [transformationId], references: [id], onDelete: Cascade)
  transformationId String

  // Link to the Ingredient that is generated
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String // Removed @unique to allow multiple transformations to produce the same ingredient

  weight         Float // Actual output weight from the test (e.g., 6.5 KG)
  percentage     Float // e.g. 60.0 (60%) yield of the source weight
  costAllocation Float // e.g. 1.2 (Allocates 1.2x cost per kg relative to source avg)
}

// -----------------------------------------------------------------------------

// Formatos de compra (e.g. "Saco 25kg")
model PurchaseFormat {
  id                String @id @default(cuid())
  name              String
  quantityPerFormat Float // e.g. 25
  formatUnit        String // e.g. KG
  price             Float // Price for the whole format (e.g. 25 EUR)

  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 3. Recipes (Elaboraciones)
model Recipe {
  id            String  @id @default(cuid())
  name          String
  version       Int     @default(1)
  yieldQuantity Float // e.g. 10 (Servings) or 2 (KG)
  yieldUnit     String? // Optional unit
  instructions  String?
  isSubRecipe   Boolean @default(false)

  category       String  @default("ELABORACION_FINAL") // PRODUCTO_NO_ELABORADO, ELABORACION_INTERMEDIA, ELABORACION_FINAL
  classification String? // Old "Category" (e.g. Postres, Salsas)
  packaging      String?
  portions       Int?
  prepTime       Int? // Minutes
  cookTime       Int? // Minutes

  // Diet & Allergens
  isGlutenFree  Boolean @default(false)
  isVegan       Boolean @default(false)
  isVegetarian  Boolean @default(false)
  isLactoseFree Boolean @default(false)
  allergens     String?

  steps RecipeStep[]

  items RecipeItem[] @relation("RecipeToItems")

  // Inverse relation: This recipe can be used as an item in other recipes (if it's a sub-recipe)
  usedInRecipes RecipeItem[] @relation("SubRecipeRef")

  // For Events
  menuItems EventMenuItem[]

  // For Tasks (Production tasks)
  tasks Task[]

  // Ciclos de producción recurrentes que usan esta receta
  productionRoutines ProductionRoutine[] @relation("ProductionRoutineRecipe")

  // Motor de tareas único (Fase 3, Frente B)
  taskDefinitions TaskDefinition[] @relation("TaskDefinitionRecipe")
  taskInstances   TaskInstance[]   @relation("TaskInstanceRecipe")

  // For Mise En Place
  miseEnPlaceTasks MiseEnPlaceTask[]

  // Inverse relation: This recipe used as a sub-recipe in steps
  usedInSteps RecipeStep[] @relation("SubRecipeStep")

  // Inverse relation: This recipe used as a sub-recipe in step ingredients
  usedInStepIngredients RecipeStepIngredient[]
  menuServiceItems      MenuServiceItem[]
  salesRecords          SalesRecord[]

  // Puentes convergencia obrador → núcleo (Frente A, aditivo).
  obradorBatches ObradorProductionBatch[] @relation("ObradorBatchToRecipe")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String?
  business   Business? @relation("RecipeBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // Aislamiento por local (centro de trabajo). Nullable durante la transición.
  locationId String?
  location   Location? @relation("RecipeLocation", fields: [locationId], references: [id])

  @@index([locationId])
}

model RecipeStep {
  id String @id @default(cuid())

  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  order       Int
  description String

  // Structured Data
  action    String? // CORTAR, DESPIEZAR, COCCION
  subAction String? // BRUNOISSE, FILETEAR, AL_VACIO

  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  ingredientId String?

  subRecipe   Recipe? @relation("SubRecipeStep", fields: [subRecipeId], references: [id])
  subRecipeId String?

  // New Relation: Multiple Ingredients/SubRecipes per step
  stepIngredients RecipeStepIngredient[]
}

model RecipeStepIngredient {
  id String @id @default(cuid())

  step   RecipeStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  stepId String

  // Link to Ingredient
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  ingredientId String?

  // Link to SubRecipe
  subRecipe   Recipe? @relation(fields: [subRecipeId], references: [id])
  subRecipeId String?

  // Action per ingredient
  action    String?
  subAction String?
}

// Lines in a recipe (Ingredients or other Recipes)
model RecipeItem {
  id String @id @default(cuid())

  recipe   Recipe @relation("RecipeToItems", fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String

  type String // INGREDIENT, SUB_RECIPE

  // Link to Ingredient
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  ingredientId String?

  // Link to Recipe (Sub-recipe)
  subRecipe   Recipe? @relation("SubRecipeRef", fields: [subRecipeId], references: [id])
  subRecipeId String?

  quantityGross Float // Quantity needed before cleaning/prep
  quantityNet   Float? // Optional: Net quantity actually used
  unit          String

  // Link to a specific Supplier Product (Optional: to enforce a specific brand/provider)
  sourceProduct   SupplierProduct? @relation(fields: [sourceProductId], references: [id])
  sourceProductId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 4. Events
model Event {
  id           String   @id @default(cuid())
  name         String
  date         DateTime
  pax          Int // Number of guests
  safetyMargin Float    @default(1.1) // 1.1 = +10%
  status       String   @default("DRAFT") // DRAFT, CONFIRMED, COMPLETED

  menuItems EventMenuItem[]
  tasks     Task[]          @relation("EventTasks")

  // Motor de tareas único (Fase 3, Frente B)
  taskDefinitions TaskDefinition[] @relation("TaskDefinitionEvent")
  taskInstances   TaskInstance[]   @relation("TaskInstanceEvent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String?
  business   Business? @relation("EventBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // Aislamiento por local. Nullable durante la transición.
  locationId String?
  location   Location? @relation("EventLocation", fields: [locationId], references: [id])

  @@index([locationId])
}

model EventMenuItem {
  id      String @id @default(cuid())
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String

  recipe   Recipe @relation(fields: [recipeId], references: [id])
  recipeId String

  servingsOverride Int? // If different from Event PAX
}

// 5. Tasks
model Task {
  id          String  @id @default(cuid())
  title       String
  description String?

  assignedTo       User?   @relation("AssignedTasks", fields: [assignedToUserId], references: [id])
  assignedToUserId String?

  status      String  @default("PENDING") // PENDING, IN_PROGRESS, DONE, ISSUE
  issueReason String?

  plannedStart DateTime?
  plannedEnd   DateTime?
  realStart    DateTime?
  realEnd      DateTime?

  // Orden manual del empleado en su vista del día (NULL = sin reordenar, manda la hora).
  sortOrder Int?

  // Linking a task to a recipe production
  recipe         Recipe? @relation(fields: [recipeId], references: [id])
  recipeId       String?
  targetQuantity Float? // How much to produce
  unit           String? // KG, UD, etc.

  // Granular Metadata
  action    String? // CORTAR, DESPIEZAR, COCCION, etc.
  technique String? // BRUNOISSE, AL_VACIO, etc.

  // Many-to-Many Relationship with Events (for aggregation)
  events Event[] @relation("EventTasks")

  // Ciclo de producción recurrente que generó esta tarea (si aplica).
  productionRoutineId String?
  productionRoutine   ProductionRoutine? @relation(fields: [productionRoutineId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String?
  business   Business? @relation("TaskBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // Aislamiento por local. Nullable durante la transición.
  locationId String?
  location   Location? @relation("TaskLocation", fields: [locationId], references: [id])

  @@index([locationId])
  @@index([productionRoutineId])
}

// Ciclo de producción recurrente: plantilla que genera Task de producción/cocina/
// limpieza según su frecuencia (reutiliza la lógica de recurrencia de los checklists).
model ProductionRoutine {
  id          String  @id @default(cuid())
  title       String
  description String?

  // Datos que se copian a cada Task generada.
  recipeId       String?
  recipe         Recipe? @relation("ProductionRoutineRecipe", fields: [recipeId], references: [id])
  action         String? // CORTAR, DESPIEZAR, COCCION, LIMPIEZA, etc.
  technique      String?
