// ============================================================================
// 9. LOCATIONS (multi-local bajo un mismo admin/cliente)
// ============================================================================
// Empresa = empleador legal (razón social + NIF). Nivel intermedio entre la
// cuenta de cliente (tenant/owner) y el local. Una cuenta puede agrupar varias
// empresas; cada empresa, varios locales. El empleo se vinculará a la empresa
// (no al local) para reflejar la relación contractual y evitar representar
// cesión ilegal de trabajadores. En el caso simple (cliente = empresa) habrá
// una sola empresa por cuenta y la UI colapsa el nivel.
model Empresa {
  id            String  @id @default(cuid())
  razonSocial   String // Nombre legal (razón social)
  comercialName String? // Nombre comercial
  nif           String? // CIF/NIF
  address       String?
  phone         String?
  email         String?
  isActive      Boolean @default(true)

  // Cuenta de cliente (tenant) propietaria de la empresa.
  businessId String?
  business   Business? @relation("EmpresaBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // Locales / centros de trabajo de esta empresa.
  locations Location[] @relation("EmpresaLocations")

  // Contratos de empleo de esta empresa (el empleo se vincula a la empresa).
  employments Employment[] @relation("EmpresaEmployments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Employment = relación contractual entre una persona (User) y una Empresa.
// El empleo se vincula a la EMPRESA (empleador legal), no al local. Una persona
// puede tener varios contratos (uno por empresa); para trabajar en locales de
// otra empresa necesita un contrato propio con esa empresa, de modo que la
// cesión ilegal de trabajadores queda imposible por diseño. Dentro de su
// empresa, el empleado puede asignarse a varios locales (assignedLocations).
model Employment {
  id String @id @default(cuid())

  // Persona empleada
  userId String
  user   User   @relation("UserEmployments", fields: [userId], references: [id], onDelete: Cascade)

  // Empresa empleadora (parte contractual)
  empresaId String
  empresa   Empresa @relation("EmpresaEmployments", fields: [empresaId], references: [id], onDelete: Cascade)

  position     String? // Puesto / categoría
  contractType String? // INDEFINIDO, TEMPORAL, FORMACION, PRACTICAS, FIJO_DISCONTINUO...
  startDate    DateTime?
  endDate      DateTime? // null = vigente
  isActive     Boolean   @default(true)

  // Centros de trabajo (locales) de la empresa a los que está asignado.
  assignedLocations Location[] @relation("EmploymentLocations")

  // Permisos granulares (10) sobre la app, mapeados a los grupos del sidebar
  // (apps/web/app/ui/dashboard/nav-links.ts). Estos flags reemplazan al modelo
  // anterior BusinessAccess: el "acceso" a la app es ahora una propiedad del
  // contrato laboral. Si añades un grupo nuevo al sidebar, añade aquí su flag.
  canViewDashboard      Boolean @default(true)
  canViewEvents         Boolean @default(true)
  canViewTasks          Boolean @default(true)
  canViewCommunications Boolean @default(true)
  canViewCatalog        Boolean @default(true)
  canViewOperations     Boolean @default(true)
  canViewObrador        Boolean @default(true)
  canViewEcommerce      Boolean @default(false)
  canViewEmployees      Boolean @default(false)
  canManageDirectory    Boolean @default(false)
  canEditSettings       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([empresaId])
}

model Location {
  id        String  @id @default(cuid())
  name      String
  shortCode String?
  address   String?
  isActive  Boolean @default(true)

  // Datos de establecimiento (antes en ObradorConfig, ahora por local). Se usan
  // en el etiquetado (operador, nº de registro, origen) y la ficha del local.
  companyName    String? // Razón social
  nif            String?
  phone          String?
  email          String?
  activity       String? // restaurante, obrador, elaboración propia, etc.
  registryType   String? // Registro autonómico, RGSEAA, etc.
  registryNumber String? // Nº RGSEAA / registro sanitario
  registryStatus String?   @default("no_iniciado")
  region         String? // Comunidad autónoma
  requestDate    DateTime?
  resolutionDate DateTime?

  businessId String?
  business   Business? @relation("LocationBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // Empresa (empleador legal) a la que pertenece este local / centro de trabajo.
  // Nullable durante la transición: los locales existentes se vincularán por backfill.
  empresaId String?
  empresa   Empresa? @relation("EmpresaLocations", fields: [empresaId], references: [id])

  // Empleados asignados a este centro de trabajo (vía su contrato de empleo).
  employments Employment[] @relation("EmploymentLocations")

  members            User[]              @relation("LocationMembers")
  apiKeys            IntegrationApiKey[] @relation("IntegrationApiKeyLocation")
  recipes            Recipe[]            @relation("RecipeLocation")
  ingredients        Ingredient[]        @relation("IngredientLocation")
  masterProducts     MasterProduct[]     @relation("MasterProductLocation")
  supplierProducts2  SupplierProduct[]   @relation("SupplierProductLocation")
  suppliers          Supplier[]          @relation("SupplierLocation")
  events             Event[]             @relation("EventLocation")
  tasks              Task[]              @relation("TaskLocation")
  productionRoutines ProductionRoutine[] @relation("ProductionRoutineLocation")
  taskDefinitions    TaskDefinition[]    @relation("TaskDefinitionLocation")
  taskSchedules      TaskSchedule[]      @relation("TaskScheduleLocation")
  taskInstances      TaskInstance[]      @relation("TaskInstanceLocation")
  menuServices       MenuService[]       @relation("MenuServiceLocation")
  templates          ChecklistTemplate[] @relation("ChecklistTemplateLocation")
  schedules          ChecklistSchedule[] @relation("ChecklistScheduleLocation")
  communications     Communication[]     @relation("CommunicationLocation")
  productLabels      ProductLabel[]      @relation("ProductLabelLocation")
  customers          Customer[]          @relation("CustomerLocation")
  onlineOrders       OnlineOrder[]       @relation("OnlineOrderLocation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// 10. CHECKLISTS (patrón yurest: Plantilla → Programación → Instancia → Respuesta)
// ============================================================================

enum ChecklistFieldType {
  TITLE
  CHECK
  TEXT
  YES_NO
  RATING_1_10
}

enum PhotoRequirement {
  NONE
  OPTIONAL
  REQUIRED
}

enum Frequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum InstanceStatus {
  PENDING
  IN_PROGRESS
  DONE
  CLOSED_AUTO
  INCIDENT
}

model ChecklistTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  businessId String?
  business   Business? @relation("ChecklistTemplateBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // null = aplicable a todos los locales del owner
  locationId String?
  location   Location? @relation("ChecklistTemplateLocation", fields: [locationId], references: [id])

  fields    ChecklistField[]
  schedules ChecklistSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistField {
  id               String             @id @default(cuid())
  templateId       String
  template         ChecklistTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order            Int
  type             ChecklistFieldType
  name             String
  description      String?
  exampleImageUrl  String?
  photoRequirement PhotoRequirement   @default(NONE)

  responses ChecklistResponse[]
}

model ChecklistSchedule {
  id         String            @id @default(cuid())
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id])

  locationId String
  location   Location @relation("ChecklistScheduleLocation", fields: [locationId], references: [id])

  frequency          Frequency
  startDate          DateTime
  endDate            DateTime?
  executionStartTime String // "HH:MM"
  executionEndTime   String // "HH:MM"
  excludeWeekdays    Int[]     @default([]) // 0=domingo … 6=sábado
  autoClose          Boolean   @default(false)
  pinned             Boolean   @default(false)

  // Asignación (string[] de User ids para flexibilidad inicial)
  performerUserIds  String[] @default([])
  supervisorUserIds String[] @default([])
  followerUserIds   String[] @default([])
  performerRoles    String[] @default([])
  supervisorRoles   String[] @default([])
  followerRoles     String[] @default([])

  businessId String?
  business   Business? @relation("ChecklistScheduleBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  instances ChecklistInstance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistInstance {
  id         String            @id @default(cuid())
  scheduleId String
  schedule   ChecklistSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  dueDate    DateTime

  status         InstanceStatus @default(PENDING)
  openedAt       DateTime?
  closedAt       DateTime?
  closedByUserId String?
  closedBy       User?          @relation("ChecklistInstanceClosedBy", fields: [closedByUserId], references: [id])
  scoreAvg       Float?

  // Asignación a una persona concreta (sobre el pool de ejecutores de la programación).
  assignedToUserId String?
  assignedTo       User?   @relation("ChecklistInstanceAssignee", fields: [assignedToUserId], references: [id])

  responses ChecklistResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scheduleId, dueDate])
  @@index([assignedToUserId])
}

// ============================================================================
// 11. COMUNICACIONES (averías, avisos, eventos, reuniones — patrón yurest)
// ============================================================================

enum CommunicationType {
  BREAKDOWN // Avería
  NOTICE // Aviso
  EVENT // Evento
  MEETING // Reunión
  TASK // Tarea programada (Comunicación > Programadas)
  LIST // Listas
}

enum CommunicationStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model Communication {
  id          String              @id @default(cuid())
  type        CommunicationType
  title       String
  description String?
  status      CommunicationStatus @default(OPEN)

  // Multi-tenancy
  businessId String?
  business   Business? @relation("CommunicationBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // Local opcional
  locationId String?
  location   Location? @relation("CommunicationLocation", fields: [locationId], references: [id])

  // Autor
  authorId String
  author   User   @relation("CommunicationAuthor", fields: [authorId], references: [id])

  // Asignados / seguidores (arrays simples como en Schedule)
  assigneeIds String[] @default([])
  followerIds String[] @default([])

  // Programación opcional (para type=TASK)
  scheduledAt DateTime?
  closedAt    DateTime?

  // Fotos / adjuntos (URLs CDN)
  photoUrls String[] @default([])

  comments CommunicationComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunicationComment {
  id              String        @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("CommunicationCommentAuthor", fields: [authorId], references: [id])

  body   String
  photos String[] @default([])

  createdAt DateTime @default(now())
}

model ChecklistResponse {
  id         String            @id @default(cuid())
  instanceId String
  instance   ChecklistInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  fieldId    String
  field      ChecklistField    @relation(fields: [fieldId], references: [id])

  valueText    String?
  valueBool    Boolean?
  valueRating  Int?
  photoUrl     String?
  photoKey     String?
  isIncident   Boolean  @default(false)
  incidentNote String?

  answeredByUserId String?
  answeredBy       User?     @relation("ChecklistResponseAnsweredBy", fields: [answeredByUserId], references: [id])
  answeredAt       DateTime?

  supervisedByUserId String?
  supervisedBy       User?     @relation("ChecklistResponseSupervisedBy", fields: [supervisedByUserId], references: [id])
  supervisedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instanceId, fieldId])
}

// ============================================================================
// 14B. MOTOR DE TAREAS ÚNICO (Fase 3, Frente B) — PASO 1: schema aditivo.
// Modelo unificado que convergerá Task + Checklist* + MiseEnPlaceTask + limpieza
// del obrador bajo una base común. Convive con los modelos actuales hasta el
// backfill y el cutover; de momento NADIE lo usa todavía.
//   - TaskDefinition: plantilla (operativa: campos+frecuencia / producción: receta).
//   - TaskField:      campos tipados de una definición operativa (= ChecklistField).
//   - TaskSchedule:   recurrencia/asignación (= ChecklistSchedule).
//   - TaskInstance:   ocurrencia concreta = base común (Task + ChecklistInstance).
//   - TaskResponse:   respuesta por campo (= ChecklistResponse).
// ============================================================================

enum TaskFamily {
  OPERATIONAL // checklists, limpieza, controles, manual operativa
  PRODUCTION // elaboración de recetas, mise en place
}

enum TaskOrigin {
  MANUAL
  CHECKLIST
  CLEANING
  PRODUCTION
  MISE_EN_PLACE
}

enum TaskFieldType {
  TITLE
  CHECK
  TEXT
  YES_NO
  RATING_1_10
}

enum TaskInstanceStatus {
  PENDING
  IN_PROGRESS
  DONE
  ISSUE
  CLOSED_AUTO
}

model TaskDefinition {
  id          String     @id @default(cuid())
  family      TaskFamily
  origin      TaskOrigin @default(MANUAL)
  title       String
  description String?
  isActive    Boolean    @default(true)

  // Operativa: campos tipados + recurrencia.
  fields    TaskField[]
  schedules TaskSchedule[]

  // Producción: vínculo a receta / evento / cantidad objetivo.
  recipeId       String?
  recipe         Recipe? @relation("TaskDefinitionRecipe", fields: [recipeId], references: [id])
  eventId        String?
  event          Event?  @relation("TaskDefinitionEvent", fields: [eventId], references: [id])
  targetQuantity Float?
  unit           String?

  // Estación / metadata de producción.
  station   String?
  action    String?
  technique String?

  instances TaskInstance[]

  businessId String?
  business   Business? @relation("TaskDefinitionBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  // Aislamiento por local. Nullable durante la transición.
  locationId String?
  location   Location? @relation("TaskDefinitionLocation", fields: [locationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([family, origin])
}

model TaskField {
  id               String           @id @default(cuid())
  definitionId     String
  definition       TaskDefinition   @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  order            Int
  type             TaskFieldType
  name             String
  description      String?
  exampleImageUrl  String?
  photoRequirement PhotoRequirement @default(NONE)

  responses TaskResponse[]
}

model TaskSchedule {
  id           String         @id @default(cuid())
  definitionId String
  definition   TaskDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  frequency          Frequency
  startDate          DateTime
  endDate            DateTime?
  executionStartTime String // "HH:MM"
  executionEndTime   String // "HH:MM"
  excludeWeekdays    Int[]     @default([]) // 0=domingo … 6=sábado
  autoClose          Boolean   @default(false)
  pinned             Boolean   @default(false)

  // Asignación (string[] de User ids/roles, como en ChecklistSchedule).
  performerUserIds  String[] @default([])
  supervisorUserIds String[] @default([])
  followerUserIds   String[] @default([])
  performerRoles    String[] @default([])
  supervisorRoles   String[] @default([])
  followerRoles     String[] @default([])

  instances TaskInstance[]

  businessId String?
  business   Business? @relation("TaskScheduleBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  locationId String?
  location   Location? @relation("TaskScheduleLocation", fields: [locationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

model TaskInstance {
  id     String     @id @default(cuid())
  family TaskFamily
  origin TaskOrigin @default(MANUAL)

  // Plantilla / recurrencia de origen (null en tareas sueltas manuales/producción).
  definitionId String?
  definition   TaskDefinition? @relation(fields: [definitionId], references: [id])
  scheduleId   String?
  schedule     TaskSchedule?   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  dueDate      DateTime?

  // Datos propios (cuando no hay plantilla: tarea manual/producción).
  title       String?
  description String?

  status      TaskInstanceStatus @default(PENDING)
  issueReason String?

  // Asignación y tiempos.
  assignedToUserId String?
  assignedTo       User?     @relation("TaskInstanceAssignee", fields: [assignedToUserId], references: [id])
  plannedStart     DateTime?
  plannedEnd       DateTime?
  realStart        DateTime?
  realEnd          DateTime?
  openedAt         DateTime?
  closedAt         DateTime?
  closedByUserId   String?
  closedBy         User?     @relation("TaskInstanceClosedBy", fields: [closedByUserId], references: [id])
  scoreAvg         Float?

  // Producción.
  recipeId         String?
  recipe           Recipe? @relation("TaskInstanceRecipe", fields: [recipeId], references: [id])
  eventId          String?
  event            Event?  @relation("TaskInstanceEvent", fields: [eventId], references: [id])
  targetQuantity   Float?
  unit             String?
  producedQuantity Float?
  action           String?
  technique        String?

  // Operativa: respuestas por campo.
  responses TaskResponse[]

  businessId String?
  business   Business? @relation("TaskInstanceBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  locationId String?
  location   Location? @relation("TaskInstanceLocation", fields: [locationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
  @@index([family, status])
  @@index([scheduleId, dueDate])
}

model TaskResponse {
  id         String       @id @default(cuid())
  instanceId String
  instance   TaskInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  fieldId    String
  field      TaskField    @relation(fields: [fieldId], references: [id])

  valueText    String?
  valueBool    Boolean?
  valueRating  Int?
  photoUrl     String?
  photoKey     String?
  isIncident   Boolean  @default(false)
  incidentNote String?

  answeredByUserId String?
  answeredBy       User?     @relation("TaskResponseAnsweredBy", fields: [answeredByUserId], references: [id])
  answeredAt       DateTime?

  supervisedByUserId String?
  supervisedBy       User?     @relation("TaskResponseSupervisedBy", fields: [supervisedByUserId], references: [id])
  supervisedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instanceId, fieldId])
}

// ============================================================================
// 15. PEDIDOS A PROVEEDORES + ALBARANES (yurest order + delivery-note)
// ============================================================================

enum PurchaseOrderStatus {
  DRAFT // borrador editable
  SENT // enviado al proveedor
  RECEIVED // mercancía recibida (parcial o total)
  CLOSED // cerrado, no se aceptan cambios
  CANCELLED
}

model PurchaseOrder {
  id String @id @default(cuid())

  businessId String?
  business   Business? @relation("PurchaseOrderBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  createdByUserId String?
  createdBy       User?   @relation("PurchaseOrderCreator", fields: [createdByUserId], references: [id])

  supplierId String
  supplier   Supplier @relation("PurchaseOrderSupplier", fields: [supplierId], references: [id])

  status PurchaseOrderStatus @default(DRAFT)

  reference    String? // número/referencia del pedido
  expectedDate DateTime?
  sentAt       DateTime?
  closedAt     DateTime?
  notes        String?

  lines         PurchaseOrderLine[]
  deliveryNotes DeliveryNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, status])
  @@index([businessId, supplierId, createdAt])
}

model PurchaseOrderLine {
  id String @id @default(cuid())

  orderId String
  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Producto puede ser de catálogo (SupplierProduct) o ad-hoc por texto
  supplierProductId String?
  supplierProduct   SupplierProduct? @relation("PurchaseOrderLineProduct", fields: [supplierProductId], references: [id])

  productName String // siempre rellenado para no perder histórico
  unit        String // KG, UD, L, BOX...
  quantity    Float
  unitPrice   Float? // opcional

  // Lo que finalmente se recibió (puede ser distinto)
  receivedQuantity Float? @default(0)
}

model DeliveryNote {
  id String @id @default(cuid())

  orderId String
  order   PurchaseOrder @relation(fields: [orderId], references: [id])

  receivedByUserId String?
  receivedBy       User?   @relation("DeliveryNoteReceiver", fields: [receivedByUserId], references: [id])

  receivedAt DateTime @default(now())

  photoUrls    String[] @default([]) // fotos del albarán/mercancía
  signatureSvg String? // firma del receptor
  note         String?

  // Opcionalmente las líneas concretas recibidas (si parcial)
  receivedLines Json? // [{orderLineId, qty}]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// 16. ETIQUETAS DE PRODUCTOS (yurest labeled-store) — trazabilidad alimentaria
// ============================================================================

enum LabelStorageMode {
  AMBIENT
  REFRIGERATED
  FROZEN
}

// Destino de la etiqueta: trazabilidad de producción (uso interno) o etiqueta legal de venta.
enum LabelDestination {
  INTERNAL
  SALE
}

model ProductLabel {
  id String @id @default(cuid())

  businessId String?
  business   Business? @relation("ProductLabelBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  createdByUserId String?
  createdBy       User?   @relation("ProductLabelCreator", fields: [createdByUserId], references: [id])

  locationId String?
  location   Location? @relation("ProductLabelLocation", fields: [locationId], references: [id])

  destination LabelDestination @default(INTERNAL)

  productName    String
  lotNumber      String?
  productionDate DateTime
  expiryDate     DateTime?
  storageMode    LabelStorageMode @default(REFRIGERATED)
  allergens      String[]         @default([])
  ingredients    String?
  weight         String? // "500 g", "2 kg", etc.
  note           String?
  photoUrl       String?

  // --- Etiqueta de venta (destination = SALE) ---
  // Referencia a la ficha del producto y al lote de obrador (trazabilidad ascendente).
  masterProductId String?
  masterProduct   MasterProduct?          @relation("MasterProductLabels", fields: [masterProductId], references: [id])
  obradorBatchId  String?
  obradorBatch    ObradorProductionBatch? @relation("ObradorBatchLabels", fields: [obradorBatchId], references: [id])

  // Snapshot legal: copia congelada al crear la etiqueta, para que una etiqueta ya
  // impresa no cambie si luego se edita la ficha del producto.
  legalDenomination String?
  registryNumber    String? // nº de registro sanitario (del local o ObradorConfig)
  origin            String?
  usageInstructions String?
  requiresCooking   Boolean?
  labelTemplate     String? // 100x70, 100x50, 80x50, 60x40
  nutritionSnapshot Json? // { energyKj, energyKcal, fat, saturatedFat, carbs, sugars, protein, salt }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, productionDate])
  @@index([businessId, locationId, productionDate])
  @@index([businessId, destination, productionDate])
}

// ============================================================================
// 17. ECOMMERCE — PEDIDOS DE LA TIENDA WEB (online)
// ============================================================================
// La tienda web (WEB SOTOdelPRIOR) cobra con Stripe y, tras confirmarse el pago,
// reenvía el pedido al obrador vía la API de integración del local
// (IntegrationApiKey → Location). El obrador es la fuente de verdad del catálogo
// (MasterProduct.isSellableOnline) y de los pedidos online. Desde aquí se inicia
// producción, se etiqueta (ProductLabel destination=SALE) y se vuelca el cliente
// al CRM (Customer). Todo aislado por local → multi-restaurante.

enum OnlineOrderStatus {
  NEW // recibido y pagado, pendiente de gestionar
  IN_PRODUCTION // se ha iniciado la elaboración / preparación
  LABELED // etiquetado y listo para envío
  SHIPPED // enviado
  DELIVERED // entregado
  CANCELLED
}

model OnlineOrder {
  id String @id @default(cuid())

  // Tenant / local que gestiona el pedido (resuelto por la API key de la web).
  businessId String?
  business   Business? @relation("OnlineOrderBusiness", fields: [businessId], references: [id], onDelete: SetNull)
  locationId String
  location   Location  @relation("OnlineOrderLocation", fields: [locationId], references: [id])

  // Referencia legible para el operario y el cliente.
  reference String @unique // p.ej. WEB-YYYYMMDD-NNN

  status OnlineOrderStatus @default(NEW)

  // Datos del cliente / envío (copiados del checkout de la web).
  customerName  String
  customerEmail String
  phone         String?
  address       String?
  city          String?
  zipCode       String?
  notes         String?

  // Importe total (euros, IVA incl.) calculado y cobrado en la web.
  total Float

  // Pago (Stripe). La web cobra; aquí guardamos la referencia para conciliar.
  paymentRef      String? // PaymentIntent id de Stripe
  paymentProvider String  @default("stripe")

  // Vínculo opcional al cliente del CRM (upsert al recibir el pedido).
  customerId String?
  customer   Customer? @relation("OnlineOrderCustomer", fields: [customerId], references: [id])

  items OnlineOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId, status])
  @@index([businessId, createdAt])
}

model OnlineOrderItem {
  id String @id @default(cuid())

  orderId String
  order   OnlineOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Producto de catálogo. Se conserva el nombre por si la ficha cambia luego.
  masterProductId String?
  masterProduct   MasterProduct? @relation(fields: [masterProductId], references: [id])

  productName     String
  quantity        Int
  priceAtPurchase Float // precio unitario cobrado (euros)
}

// ============================================================================
// 19. PUSH NOTIFICATIONS (Web Push API + VAPID)
// ============================================================================

model PushSubscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint  String  @unique
  p256dh    String
  auth      String
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Clave de la API de integración (lectura) por LOCAL. La consume el CRM para
// tirar de operarios y tiempos de tareas de un local concreto. Cada local
// genera y rota su propia clave desde Ajustes; el CRM resuelve el `locationId`
// por la clave y la API devuelve sólo las tareas/empleados de ese local. Así
// un CRM no ve datos cruzados con otros locales de la misma empresa.
model IntegrationApiKey {
  id         String   @id @default(cuid())
  key        String   @unique
  locationId String
  location   Location @relation("IntegrationApiKeyLocation", fields: [locationId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([locationId])
}
